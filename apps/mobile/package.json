{
  "name": "yiru-mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Yiru companion app for iOS and Android",
  "homepage": "https://github.com/xinyao27/yiru#readme",
  "bugs": {
    "url": "https://github.com/xinyao27/yiru/issues"
  },
  "license": "MIT",
  "author": {
    "name": "xinyao",
    "email": "hi@xinyao.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xinyao27/yiru.git",
    "directory": "apps/mobile"
  },
  "funding": "https://github.com/sponsors/xinyao27",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node scripts/start-expo.mjs",
    "dev": "node scripts/start-expo.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "postinstall": "node scripts/build-terminal-webview-engine.mjs",
    "typecheck": "tsc --noEmit",
    "fmt": "pnpm --workspace-root exec vp fmt apps/mobile",
    "format": "pnpm --workspace-root exec vp fmt apps/mobile",
    "lint": "pnpm --workspace-root exec vp lint apps/mobile --fix",
    "check": "pnpm run lint && pnpm run fmt && pnpm run typecheck",
    "test": "vp test",
    "up": "taze major -Ir",
    "format:check": "pnpm --workspace-root exec vp fmt apps/mobile --check",
    "start:emulator": "node scripts/start-emulator.mjs"
  },
  "dependencies": {
    "@noble/hashes": "catalog:mobile",
    "@react-native-async-storage/async-storage": "catalog:mobile",
    "@xterm/addon-unicode11": "catalog:mobile",
    "@xterm/addon-webgl": "catalog:mobile",
    "@xterm/xterm": "catalog:mobile",
    "@yiru/expo-two-way-audio": "catalog:mobile",
    "@yiru/mobile-relay-protocol": "catalog:",
    "@yiru/runtime-protocol": "catalog:",
    "@yiru/workbench-model": "catalog:",
    "buffer": "catalog:mobile",
    "clsx": "catalog:mobile",
    "expo": "catalog:mobile",
    "expo-build-properties": "catalog:mobile",
    "expo-camera": "catalog:mobile",
    "expo-clipboard": "catalog:mobile",
    "expo-constants": "catalog:mobile",
    "expo-crypto": "catalog:mobile",
    "expo-dev-client": "catalog:mobile",
    "expo-document-picker": "catalog:mobile",
    "expo-file-system": "catalog:mobile",
    "expo-haptics": "catalog:mobile",
    "expo-image-manipulator": "catalog:mobile",
    "expo-image-picker": "catalog:mobile",
    "expo-keep-awake": "catalog:mobile",
    "expo-linking": "catalog:mobile",
    "expo-modules-core": "catalog:mobile",
    "expo-network": "catalog:mobile",
    "expo-notifications": "catalog:mobile",
    "expo-router": "catalog:mobile",
    "expo-secure-store": "catalog:mobile",
    "expo-splash-screen": "catalog:mobile",
    "expo-status-bar": "catalog:mobile",
    "lowlight": "catalog:mobile",
    "phosphor-react-native": "catalog:mobile",
    "react": "catalog:mobile",
    "react-dom": "catalog:mobile",
    "react-native": "catalog:mobile",
    "react-native-gesture-handler": "catalog:mobile",
    "react-native-reanimated": "catalog:mobile",
    "react-native-safe-area-context": "catalog:mobile",
    "react-native-screens": "catalog:mobile",
    "react-native-svg": "catalog:mobile",
    "react-native-web": "catalog:mobile",
    "react-native-webview": "catalog:mobile",
    "react-native-worklets": "catalog:mobile",
    "tailwind-merge": "catalog:mobile",
    "tailwindcss": "catalog:mobile",
    "tweetnacl": "catalog:mobile",
    "uniwind": "catalog:mobile",
    "ws": "catalog:mobile",
    "zod": "catalog:mobile",
    "zustand": "catalog:mobile"
  },
  "devDependencies": {
    "@types/react": "catalog:mobile",
    "@types/ws": "catalog:mobile",
    "expo-module-scripts": "catalog:mobile",
    "rolldown": "catalog:",
    "taze": "catalog:",
    "typescript": "catalog:mobile",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.15.0"
}
