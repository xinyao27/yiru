{
  "name": "@yiru/workspace",
  "version": "0.0.7",
  "private": true,
  "description": "Yiru monorepo workspace",
  "homepage": "https://github.com/xinyao27/yiru#readme",
  "bugs": {
    "url": "https://github.com/xinyao27/yiru/issues"
  },
  "license": "MIT",
  "author": {
    "name": "xinyao",
    "email": "hi@xinyao.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xinyao27/yiru.git"
  },
  "funding": "https://github.com/sponsors/xinyao27",
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm -r --parallel run dev",
    "dev:desktop": "pnpm --filter yiru run dev",
    "dev:mobile": "pnpm --filter yiru-mobile run dev",
    "start": "pnpm --filter yiru run start",
    "build": "vp run --filter './packages/*' build && vp run --filter yiru build",
    "build:desktop": "pnpm --filter yiru run build:desktop",
    "build:relay": "pnpm --filter yiru run build:relay",
    "build:computer-macos": "pnpm --filter yiru run build:computer-macos",
    "build:notification-status-macos": "pnpm --filter yiru run build:notification-status-macos",
    "build:native": "pnpm --filter yiru run build:native",
    "build:release": "pnpm --filter yiru run build:release",
    "build:unpack": "pnpm --filter yiru run build:unpack",
    "build:win": "pnpm --filter yiru run build:win",
    "build:mac": "pnpm --filter yiru run build:mac",
    "build:linux": "pnpm --filter yiru run build:linux",
    "build:cli": "pnpm --filter yiru run build:cli",
    "build:electron-vite": "pnpm --filter yiru run build:electron-vite",
    "build:web": "pnpm --filter yiru run build:web",
    "ensure:electron-runtime": "pnpm --filter yiru run ensure:electron-runtime",
    "verify:computer-native": "pnpm --filter yiru run verify:computer-native",
    "verify:repository-contracts": "pnpm --filter yiru run verify:repository-contracts",
    "check:max-lines-ratchet": "pnpm --filter yiru run check:max-lines-ratchet",
    "verify:bundled-skill-guides": "pnpm --filter yiru run verify:bundled-skill-guides",
    "verify:skill-bundle-manifest": "pnpm --filter yiru run verify:skill-bundle-manifest",
    "verify:localization-catalog": "pnpm --filter yiru run verify:localization-catalog",
    "sync:localization-catalog": "pnpm --filter yiru run sync:localization-catalog",
    "verify:localization-coverage": "pnpm --filter yiru run verify:localization-coverage",
    "typecheck": "pnpm --filter yiru run typecheck && pnpm --filter yiru-mobile run typecheck && pnpm --filter @yiru/expo-two-way-audio run typecheck",
    "check": "vp check --fix && pnpm run typecheck && pnpm --filter yiru run verify:repository-contracts",
    "lint": "vp lint --fix",
    "fmt": "vp fmt",
    "test": "vp test",
    "up": "taze major -Ir",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint-plugin-react-doctor": "catalog:",
    "taze": "catalog:",
    "typescript": "catalog:desktop",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@11.15.0"
}
